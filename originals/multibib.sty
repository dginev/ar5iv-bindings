% multibib.sty — minimal local stub for the multibib package.
%
% Real multibib is a non-CTAN AMS/Heller package shipping with arXiv's
% texmf-extras tree, not standard TeX Live's `latex/`. Papers with
% `\usepackage{multibib}` + `\newcites{aux}{title}` use separate
% bibliographies (e.g. main + supplementary) that compile cleanly on
% arXiv but fail through our pipeline at the `\cite<aux>` /
% `\bibliography<aux>` calls.
%
% Vendor a minimal stub: `\newcites{aux}{title}` aliases the per-list
% citation/bibliography CSes (`\cite<aux>`, `\nocite<aux>`,
% `\bibliography<aux>`, `\bibliographystyle<aux>`) to the standard ones.
% LaTeXML produces a single bibliography section anyway, so the
% multi-list structure collapses cleanly.
\ProvidesPackage{multibib}[2026/05/15 minimal local stub]

% \newcites{aux}{title} — register a per-list set of citation CSes.
\newcommand{\newcites}[2]{%
  \expandafter\let\csname cite#1\endcsname\cite
  \expandafter\let\csname nocite#1\endcsname\nocite
  \expandafter\let\csname bibliography#1\endcsname\bibliography
  \expandafter\let\csname bibliographystyle#1\endcsname\bibliographystyle
}

\endinput
